# Copy @Qualifier from instance fields onto Lombok-generated constructor
# parameters so Spring constructor injection resolves the correct bean for
# each field.
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier

# Tag Lombok-generated members (equals / hashCode / toString / getters /
# setters / @Builder bodies) with @lombok.Generated so JaCoCo 0.8.2+ excludes
# them from coverage measurement. Coverage-only effect — no production
# behaviour change.
lombok.addLombokGeneratedAnnotation = true
